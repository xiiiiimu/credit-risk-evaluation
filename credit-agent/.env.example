OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_CHAT_MODEL=deepseek-chat
SPRING_TOOL_BASE_URL=http://127.0.0.1:8082
INTERNAL_API_KEY=credit-agent-secret

# Phase 3: Agent 稳定性
AGENT_NODE_TIMEOUT_SEC=15
AGENT_CIRCUIT_FAILURE_THRESHOLD=5
AGENT_CIRCUIT_OPEN_SEC=30
LLM_RATE_LIMIT_PER_MINUTE=60
LLM_RATE_LIMIT_MAX_CONCURRENT=5
LLM_RATE_LIMIT_MAX_WAIT_SEC=30

# Phase 5: 结果缓存
CACHE_ENABLED=true
LLM_CACHE_TTL_HOURS=24
OCR_CACHE_TTL_HOURS=72
